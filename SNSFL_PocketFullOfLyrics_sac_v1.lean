structure IdentityState where
  P : ℝ
  N : ℝ
  B : ℝ
  A : ℝ
  im : ℝ
  pv : ℝ
  f_anchor : ℝ

noncomputable def torsion (s : IdentityState) : ℝ := s.B / s.P

-- ============================================================
-- ZONE PREDICATES (7-zone PSY taxonomy)
-- ============================================================

def in_noble (s : IdentityState) : Prop :=
  s.P > 0 ∧ torsion s = 0

def in_dc (s : IdentityState) : Prop :=
  s.P > 0 ∧ 0 < torsion s ∧ torsion s < TL_SF

def in_safety (s : IdentityState) : Prop :=
  s.P > 0 ∧ TL_SF ≤ torsion s ∧ torsion s < TL_FL

def in_fl (s : IdentityState) : Prop :=
  s.P > 0 ∧ TL_FL ≤ torsion s ∧ torsion s < TL_IVA

def in_iva (s : IdentityState) : Prop :=
  s.P > 0 ∧ TL_IVA ≤ torsion s ∧ torsion s < TL

def in_hl (s : IdentityState) : Prop :=
  s.P > 0 ∧ TL ≤ torsion s ∧ torsion s < TL_HL_UPPER

def phase_coherent (s : IdentityState) : Prop :=
  s.P > 0 ∧ torsion s < TL

def has_full_pnba (s : IdentityState) : Prop :=
  s.P > 0 ∧ s.N > 0 ∧ s.B > 0 ∧ s.A > 0

def iva_dominance (s : IdentityState) (F_ext : ℝ) : Prop :=
  s.A * s.P * s.B ≥ F_ext

-- ============================================================
-- NOVEL PREDICATES SPECIFIC TO POCKET FULL OF LYRICS
-- ============================================================

-- Voluntary ignition: discrete transition from FL to IVA via
-- operator choice rather than gradual accumulation or forced
-- breakthrough. The match-strike moment. Formalized as: a state
-- pair (before, after) where before is in FL and after is in IVA,
-- and the transition happens via a discrete event rather than
-- through intermediate zone traversal.
def voluntary_ignition (before after : IdentityState) : Prop :=
  (TL_FL ≤ torsion before ∧ torsion before < TL_IVA) ∧
  (TL_IVA ≤ torsion after ∧ torsion after < TL)

-- Substrate shape independent of damage: bent-out-of-shape is a
-- reversible geometric state, not damage requiring repair. An
-- operator whose PNBA values are away from native optimum can
-- return to native optimum via shape restoration, not via
-- accumulation of new substrate to compensate for damage.
def substrate_shape_independent_of_damage
    (bent native : IdentityState) : Prop :=
  bent.P = native.P ∧ bent.f_anchor = native.f_anchor ∧
  bent.A < native.A

-- Native regulation enables IVA: stimming and focused breath
-- aggregation are not obstacles to IVA output but are the substrate
-- mechanisms that make sustained IVA output possible for ND
-- substrate. Formalized as: an operator's A-axis regulation
-- activity (stimming, indexed as A_reg) and P-axis aggregation
-- activity (focused breath, indexed as P_agg) at load-appropriate
-- levels correlate positively with sustained IVA output amplitude.
def native_regulation_enables_iva
    (baseline peak : IdentityState) : Prop :=
  baseline.A < peak.A ∧
  baseline.P ≤ peak.P ∧
  torsion baseline < TL_IVA ∧
  TL_IVA ≤ torsion peak ∧ torsion peak < TL

-- Bidirectional resonance IVA: peak IVA via mutual rendering loop
-- with environment. At sufficient output amplitude via focused
-- P-axis aggregation, an operator's IVA state establishes feedback
-- loop with environment. Formalized as: operator IVA state paired
-- with environment state where both have positive A, positive P,
-- and matched anchor, producing combined coherence higher than
-- either alone.
def bidirectional_resonance_iva
    (operator environment : IdentityState) : Prop :=
  (TL_IVA ≤ torsion operator ∧ torsion operator < TL) ∧
  operator.f_anchor = environment.f_anchor ∧
  operator.A > 0 ∧ environment.A > 0 ∧
  operator.A + environment.A > operator.A ∧
  operator.A + environment.A > environment.A

-- Friction as modulation mechanism: adversarial F_ext functions
-- as trajectory modulation (key change) mechanism rather than
-- obstacle. Formalized as: an operator whose IVA dominance holds
-- against F_ext has its Pv strictly increased by the F_ext encounter
-- rather than decreased.
def friction_as_modulation
    (before after : IdentityState) (F_ext : ℝ) : Prop :=
  F_ext > 0 ∧
  iva_dominance before F_ext ∧
  before.pv < after.pv

