-- [P,9,6,1] :: {INV} | Evidence source type
-- Every import module declares its source and which axis it enriches.
inductive EvidenceAxis
  | P_evidence : EvidenceAxis  -- Pattern signal (Spotify genre lock, visual patterns)
  | N_evidence : EvidenceAxis  -- Narrative signal (word choice, post frequency)
  | B_evidence : EvidenceAxis  -- Behavior signal (likes, shares, interactions)
  | A_evidence : EvidenceAxis  -- Adaptation signal (taste evolution rate)

-- [P,9,6,2] :: {INV} | Behavioral evidence packet
-- A single observation from any external source.
-- Reduces to a PNBA signal on one axis.
-- Raw signal → normalized to [0,1] → scaled to mode weight range.
structure BehavioralEvidencePacket where
  source      : String         -- "spotify", "facebook", "purchases", etc.
  axis        : EvidenceAxis   -- which PNBA axis this enriches
  raw_signal  : ℝ              -- raw behavioral measurement
  norm_signal : ℝ              -- normalized to [0,1]
  f_ext_B     : ℝ              -- the B contribution (F_ext in the equation)
  anchor      : ℝ              -- always 1.369

-- [P,9,6,3] :: {INV} | Valid evidence packet predicate
-- A packet is valid iff norm_signal ∈ [0,1] and anchor is sovereign.
def valid_evidence (ep : BehavioralEvidencePacket) : Prop :=
  0 ≤ ep.norm_signal ∧ ep.norm_signal ≤ 1 ∧
  ep.anchor = SOVEREIGN_ANCHOR

-- [P,9,6,4] :: {INV} | F_ext from evidence
-- The behavioral signal IS F_ext in the dynamic equation.
-- Evidence changes effective B. P, N, A are structurally unchanged.
-- This is the same pattern as f_ext_op in CPP_Reduction_V3.lean.
noncomputable def evidence_as_fext (ep : BehavioralEvidencePacket) : ℝ :=
  ep.f_ext_B

-- ============================================================
-- [B] :: {RED} | EXAMPLE 2 — SPOTIFY → P EVIDENCE (KNOWN ANSWER)
--
-- Long division setup:
--   Problem:      Does Spotify listening history reduce to PNBA?
--   Known answer: Yes. Genre lock = Pattern consistency = P signal.
--                 High genre lock (same artists, same BPM) → high P evidence.
--                 Wide spread (all genres) → low P evidence.
--   PNBA mapping: genre_diversity_score → normalize → P F_ext signal
--   Plug in → high_lock_spotify.norm_signal = 0.9 → strong P evidence.
--   Matches known answer: listening patterns ARE Pattern axis data.
-- ============================================================

-- [B,9,7,1] :: {INV} | Spotify high genre lock (Pattern-dominant listener)
-- norm_signal = 0.9 (90% genre consistency over 1 year)
-- f_ext_B = 0.9 × mode_weight(F) = 0.9 × 3 = 2.7 (strong P signal)
def spotify_high_lock : BehavioralEvidencePacket :=
  { source := "spotify", axis := EvidenceAxis.P_evidence,
    raw_signal := 0.9, norm_signal := 0.9, f_ext_B := 2.7,
    anchor := SOVEREIGN_ANCHOR }

-- [B,9,7,2] :: {INV} | Spotify wide spread (low Pattern consistency)
-- norm_signal = 0.1 (10% genre consistency — explores everything)
def spotify_low_lock : BehavioralEvidencePacket :=
  { source := "spotify", axis := EvidenceAxis.P_evidence,
    raw_signal := 0.1, norm_signal := 0.1, f_ext_B := 0.3,
    anchor := SOVEREIGN_ANCHOR }

-- [B,9,7,3] :: {VER} | THEOREM 19: SPOTIFY HIGH LOCK IS VALID EVIDENCE
theorem spotify_high_lock_valid : valid_evidence spotify_high_lock := by
  unfold valid_evidence spotify_high_lock SOVEREIGN_ANCHOR; norm_num

-- [B,9,7,4] :: {VER} | THEOREM 20: HIGH LOCK STRONGER SIGNAL THAN LOW LOCK
-- A genre-locked listener produces stronger P evidence than a wide explorer.
-- The Pattern axis signal is proportional to behavioral consistency.
theorem high_lock_stronger_than_low :
    evidence_as_fext spotify_high_lock > evidence_as_fext spotify_low_lock := by
  unfold evidence_as_fext spotify_high_lock spotify_low_lock; norm_num

