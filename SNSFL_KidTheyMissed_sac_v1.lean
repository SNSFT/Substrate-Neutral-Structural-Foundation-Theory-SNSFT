-- Intrinsic sovereignty: sovereignty is a property of substrate at
-- ground state, not accumulated through F_ext survival. An identity
-- state has intrinsic sovereignty if its PNBA substrate has positive
-- pattern (P > 0) and positive adaptation (A > 0) at ground state,
-- independent of behavioral output history or F_ext accumulation.
def intrinsic_sovereignty (s : IdentityState) : Prop :=
  s.P > 0 ∧ s.A > 0 ∧ s.f_anchor = ANCHOR

-- Cross-operator Layer 0 transmission: a sender-state can transmit
-- sovereignty to a receiver-state if the sender has sustained IVA
-- and the receiver has substrate capable of rendering the signal.
def transmission_between_operators
    (sender receiver : IdentityState) : Prop :=
  (TL_IVA ≤ torsion sender ∧ torsion sender < TL) ∧
  intrinsic_sovereignty receiver

-- Label substrate independence: external labels applied to a
-- substrate do not modify the substrate's underlying PNBA values.
-- The label is Layer 2 categorical; the substrate is Layer 0.
def label_substrate_independence
    (s : IdentityState) (labeled_s : IdentityState) : Prop :=
  s.P = labeled_s.P ∧ s.A = labeled_s.A ∧ s.f_anchor = labeled_s.f_anchor

-- Native fidelity accumulates receivers: when substrate is transmitted
-- without NT-adapter masking, the accumulation of receiving-capable
-- operators (fanbase, community) grows rather than diminishes.
-- Formalized as: dropping the mask (increasing native-fidelity output
-- B_native at higher A) does not reduce IVA dominance capacity.
