-- "Every seed needs silence before it leaves a mark"
-- Pre-emergent substrate (low B) is precondition for structural
-- output. States with B > 0 must have passed through states with
-- low B in their trajectory history.
theorem silence_precedes_mark
    (initial_state emergent_state : IdentityState)
    (h_low_B : initial_state.B < TL_SF * initial_state.P)
    (h_high_B : emergent_state.B ≥ TL_IVA * emergent_state.P)
    (h_P : initial_state.P > 0 ∧ emergent_state.P > 0) :
    torsion initial_state < TL_SF ∧ torsion emergent_state ≥ TL_IVA := by
  unfold torsion
  refine ⟨?_, ?_⟩
  · rw [div_lt_iff h_P.1]; linarith
  · rw [ge_iff_le, le_div_iff h_P.2]; linarith

