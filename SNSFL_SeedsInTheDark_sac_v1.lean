    in_safety verse1_rooting_state ∧
    in_iva chorus_state ∧
    in_iva verse2_state ∧
    in_hl bridge_state ∧
    in_iva final_chorus_state := by
  exact ⟨verse1_buried_in_dc, verse1_rooting_in_safety, chorus_in_iva,
         verse2_in_iva, bridge_in_hl, final_chorus_in_iva⟩

-- T20: IVA gain — sovereign voice exceeds classical constraint
-- Same structural form as Speak In Lightning. The seed that pushes
-- through concrete achieves the same sovereignty gain factor as
-- the lightning that finds its voice.
theorem iva_voice_sovereignty
    (v_e m₀ m_f g_r : ℝ)
    (h_ve : v_e > 0)
    (h_gr : g_r ≥ 1.5)
    (h_mass : m₀ > m_f)
    (h_mf : m_f > 0) :
    v_e * (1 + g_r) * Real.log (m₀ / m_f) >
    v_e * Real.log (m₀ / m_f) := by
  have h_ratio : m₀ / m_f > 1 := by
    rw [gt_iff_lt, lt_div_iff h_mf]; linarith
